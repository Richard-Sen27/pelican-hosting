# =============================================================================
# PELICAN PANEL - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Panel
# -----------------------------------------------------------------------------
APP_URL=http://localhost          # Full URL where the panel is accessible
APP_ENV=production                # production or development
APP_DEBUG=false                   # Never true in production

# -----------------------------------------------------------------------------
# Let's Encrypt (only needed if not using an external reverse proxy)
# -----------------------------------------------------------------------------
LE_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_PASSWORD=changeme_user
MYSQL_DATABASE=panel
MYSQL_USER=pelican

# -----------------------------------------------------------------------------
# Mail (optional — leave MAIL_DRIVER=log to just log emails instead of sending)
# -----------------------------------------------------------------------------
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_FROM=noreply@example.com
# MAIL_USERNAME=your_smtp_user
# MAIL_PASSWORD=your_smtp_password
# MAIL_SCHEME=tls

# -----------------------------------------------------------------------------
# Wings
# -----------------------------------------------------------------------------
TZ=UTC                            # Timezone for game servers e.g. Europe/Berlin